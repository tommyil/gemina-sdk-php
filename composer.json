{
    "name": "gemina/sdk",
    "description": "Official PHP client for the Gemina API — invoice OCR and document intelligence: upload documents, get typed structured data back, then search, aggregate, and chat over everything you've processed.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://gemina.co",
    "keywords": [
        "gemina",
        "invoice",
        "ocr",
        "document-intelligence",
        "api",
        "sdk",
        "rest"
    ],
    "support": {
        "issues": "https://github.com/tommyil/gemina-sdk/issues",
        "email": "support@gemina.co",
        "docs": "https://console.gemina.co/docs"
    },
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "Gemina\\Sdk\\": ["lib/", "src/"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gemina\\Sdk\\Tests\\": "tests/"
        }
    }
}
